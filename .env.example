# AI Website Grader — required environment variables
# Copy to .env.local for local dev; set the same keys in Vercel for production.

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-side admin — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HubSpot embed (public)
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=your-portal-id
NEXT_PUBLIC_HUBSPOT_EXPORT_FORM_ID=your-export-form-id
NEXT_PUBLIC_HUBSPOT_CTA_FORM_ID=your-cta-form-id

# Google Tag Manager (public)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# HubSpot CRM lead push (optional — app runs without it)
HUBSPOT_ACCESS_TOKEN=your-private-app-token

# Additional allowed CORS origins (optional, comma-separated)
CORS_ALLOWED_ORIGINS=
